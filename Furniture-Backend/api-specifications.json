[
  {
    "application": "MainBackend",
    "architecture": "monolith",
    "version": "v1",
    "module": "auth",
    "basePath": "/api/auth",
    "authentication": {
      "type": "jwt",
      "required": false
    },
    "apis": [
      {
        "name": "Login",
        "method": "POST",
        "path": "/login",
        "fullPath": "/api/auth/login",
        "description": "Authenticate admin user and issue JWT tokens",
        "request": {
          "body": {
            "email": { "type": "string", "required": true },
            "password": { "type": "string", "required": true }
          }
        },
        "response": {
          "success": {
            "token": "string",
            "refreshToken": "string",
            "expiresIn": "number",
            "user": {
              "id": "uuid",
              "name": "string",
              "email": "string",
              "role": "string",
              "avatarUrl": "string"
            }
          }
        },
        "dbMapping": {
          "tables": ["users", "roles", "refresh_tokens"],
          "fields": {
            "email": "users.email",
            "password": "users.password_hash",
            "role": "roles.name",
            "avatarUrl": "users.avatar_url",
            "refreshToken": "refresh_tokens.token"
          }
        }
      },
      {
        "name": "Logout",
        "method": "POST",
        "path": "/logout",
        "fullPath": "/api/auth/logout",
        "description": "Invalidate refresh token",
        "request": {
          "body": {
            "refreshToken": { "type": "string", "required": true }
          }
        },
        "response": {
          "success": {
            "message": "Logged out successfully"
          }
        },
        "dbMapping": {
          "table": "refresh_tokens",
          "fields": {
            "refreshToken": "refresh_tokens.token"
          }
        }
      }
    ]
  },
