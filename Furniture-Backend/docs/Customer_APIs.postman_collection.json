        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/customer/catalog/search?q=sofa&page=1&limit=12",
              "host": ["{{base_url}}"],
              "path": ["api", "customer", "catalog", "search"],
              "query": [{ "key": "q", "value": "sofa" }, { "key": "page", "value": "1" }, { "key": "limit", "value": "12" }]
            }
          }
        },
        {
          "name": "Featured Products",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/customer/catalog/featured"
