        },
        {
          "name": "Get Product Reviews",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/customer/catalog/products/:id/reviews?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "customer", "catalog", "products", ":id", "reviews"],
              "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "10" }]
